{
  "name": "typing-sound-customizer",
  "version": "1.0.0",
  "description": "Every keypress makes a different sound. Farts, meows, gunshots, or moaning.",
  "main": "main.js",
  "scripts": {
    "start": "ELECTRON_RUN_AS_NODE= electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "StupidApps",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "node-global-key-listener": "^0.3.0"
  },
  "build": {
    "appId": "io.stupidapps.typing-sounds",
    "productName": "Typing Sound Customizer",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "sounds/**/*",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "sounds",
        "to": "sounds"
      }
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "target": ["dmg", "zip"],
      "icon": "icon.png"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.png"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "icon.png"
    }
  }
}
